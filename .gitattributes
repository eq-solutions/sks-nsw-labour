# Normalise all text files to LF in the repo, regardless of platform.
# Without this, Windows checkouts with core.autocrlf=true and Linux/macOS
# checkouts disagree on every file and git status lights up like a
# Christmas tree. LF in the repo + CRLF only where Windows tooling
# explicitly needs it is the standard cross-platform pattern.

* text=auto eol=lf

# Source / text files -- force LF
*.js        text eol=lf
*.mjs       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.htm       text eol=lf
*.svg       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.env*      text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# Windows-specific tooling -- force CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files -- do not touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.xlsx      binary
*.xlsm      binary
*.docx      binary
*.pptx      binary
